@model IEnumerable<HospitalManagement.DataAccess.Entities.Account>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Manage Accounts";
    var roles = ViewBag.Roles as IEnumerable<HospitalManagement.DataAccess.Entities.Role> ?? new List<HospitalManagement.DataAccess.Entities.Role>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold tracking-tight text-white mb-1">Accounts Directory</h2>
        <p class="text-secondary small mb-0">Total Accounts: @Model.Count()</p>
    </div>
    <button type="button" class="btn btn-primary hover-translate d-flex align-items-center" onclick="openCreateModal()">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi xmlns-svg me-2" viewBox="0 0 16 16">
            <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3a.5.5 0 0 1 .5-.5z"/>
        </svg>
        Add Account
    </button>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success bg-success bg-opacity-10 border-success border-opacity-20 text-success text-sm rounded-8 mb-4" role="alert">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger bg-danger bg-opacity-10 border-danger border-opacity-20 text-danger text-sm rounded-8 mb-4" role="alert">
        @TempData["Error"]
    </div>
}

<div class="card card-glass border-0 p-4">
    <div class="table-responsive">
        <table class="table table-premium text-white">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Created At</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.AccountId</td>
                        <td class="fw-bold text-white">@item.Username</td>
                        <td class="text-secondary">@item.Email</td>
                        <td>
                            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-20 px-3 py-2 small">
                                @(item.Role?.RoleName ?? "Staff")
                            </span>
                        </td>
                        <td>
                            @if (item.IsActive.GetValueOrDefault(true))
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-20 px-3 py-2 small">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-20 px-3 py-2 small">Disabled</span>
                            }
                        </td>
                        <td class="text-secondary small">@item.CreatedAt?.ToString("yyyy-MM-dd HH:mm")</td>
                        <td class="text-end">
                            <button type="button" class="btn btn-outline-light btn-sm px-3 py-2 me-1 hover-translate"
                                    onclick="openEditModal(@item.AccountId, '@item.Username', '@item.Email', @item.RoleId, '@(item.IsActive.GetValueOrDefault(true) ? "true" : "false")')">
                                Edit
                            </button>
                            <button type="button" class="btn btn-danger btn-sm px-3 py-2 bg-opacity-10 text-danger border border-danger border-opacity-20 hover-translate"
                                    onclick="openDeleteModal(@item.AccountId, '@item.Username')">
                                Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Save Modal -->
<div class="modal fade" id="saveModal" tabindex="-1" aria-labelledby="saveModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-white" id="saveModalLabel">Account Information</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Save" method="post">
                <div class="modal-body">
                    <input type="hidden" name="AccountId" id="modalAccountId" value="0" />

                    <div class="mb-3">
                        <label for="modalUsername" class="form-label text-secondary small fw-semibold">Username</label>
                        <input type="text" name="Username" id="modalUsername" class="form-control" required maxlength="50" placeholder="Username" />
                    </div>

                    <div class="mb-3">
                        <label for="modalPassword" class="form-label text-secondary small fw-semibold" id="passwordLabel">Password</label>
                        <input type="password" name="PasswordHash" id="modalPassword" class="form-control" placeholder="••••••••" />
                        <div class="text-secondary small mt-1" style="font-size: 0.75rem;" id="passwordHelp">Leave blank to keep existing password.</div>
                    </div>

                    <div class="mb-3">
                        <label for="modalEmail" class="form-label text-secondary small fw-semibold">Email</label>
                        <input type="email" name="Email" id="modalEmail" class="form-control" required placeholder="name@hospital.com" />
                    </div>

                    <div class="mb-3">
                        <label for="modalRole" class="form-label text-secondary small fw-semibold">Role</label>
                        <select name="RoleId" id="modalRole" class="form-select" required>
                            @foreach (var role in roles)
                            {
                                <option value="@role.RoleId">@role.RoleName</option>
                            }
                        </select>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" name="IsActive" id="modalIsActive" value="true" checked>
                        <label class="form-check-label text-white small" for="modalIsActive">Account Active</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-danger border-opacity-20">
                <h5 class="modal-title text-danger" id="deleteModalLabel">Confirm Deletion</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Delete" method="post">
                <div class="modal-body">
                    <input type="hidden" name="id" id="deleteAccountId" />
                    <p class="text-white">Are you sure you want to delete the account <strong id="deleteAccountUsername" class="text-primary"></strong>?</p>
                    <p class="text-secondary small">This action cannot be undone and will delete all references to this account.</p>
                </div>
                <div class="modal-footer border-danger border-opacity-20">
                    <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Confirm Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var saveModal = new bootstrap.Modal(document.getElementById('saveModal'));
        var deleteModal = new bootstrap.Modal(document.getElementById('deleteModal'));

        function openCreateModal() {
            document.getElementById('modalAccountId').value = "0";
            document.getElementById('modalUsername').value = "";
            document.getElementById('modalUsername').readOnly = false;
            document.getElementById('modalPassword').value = "";
            document.getElementById('modalPassword').required = true;
            document.getElementById('passwordHelp').style.display = "none";
            document.getElementById('modalEmail').value = "";
            document.getElementById('modalIsActive').checked = true;
            document.getElementById('saveModalLabel').innerText = "Create New Account";
            saveModal.show();
        }

        function openEditModal(id, username, email, roleId, isActive) {
            document.getElementById('modalAccountId').value = id;
            document.getElementById('modalUsername').value = username;
            document.getElementById('modalUsername').readOnly = true;
            document.getElementById('modalPassword').value = "";
            document.getElementById('modalPassword').required = false;
            document.getElementById('passwordHelp').style.display = "block";
            document.getElementById('modalEmail').value = email;
            document.getElementById('modalRole').value = roleId;
            document.getElementById('modalIsActive').checked = (isActive === "true");
            document.getElementById('saveModalLabel').innerText = "Edit Account Details";
            saveModal.show();
        }

        function openDeleteModal(id, username) {
            document.getElementById('deleteAccountId').value = id;
            document.getElementById('deleteAccountUsername').innerText = username;
            deleteModal.show();
        }
    </script>
}
