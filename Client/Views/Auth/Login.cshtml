@model HospitalManagement.BusinessObject.DTOs.LoginRequest
@{
    Layout = "_Layout";
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center align-items-center" style="min-height: 75vh;">
    <div class="col-md-5">
        <div class="card card-glass p-5 border-0">
            <div class="text-center mb-4">
                <div class="d-inline-block bg-primary bg-opacity-10 text-primary rounded-circle p-3 mb-3 hover-scale">
                    <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="currentColor" class="bi bi-hospital" viewBox="0 0 16 16">
                        <path d="M8.5 5.034v1.1l.953-.55.5.867L9 6.002v1.1h1v-.571l.953-.55.5.867-.953.55v1.1h-1v.571l-.953.55-.5-.867.953-.55v-1.1h-.953v.571l-.953.55-.5-.867.953-.55v-1.1h-1v.571l-.953-.55-.5.867.953.55v1.1h1v.571l.953.55.5-.867-.953-.55v-1.1h1zM5 14h6v-3H5v3zm1-2.5a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 .5.5v1.5H6v-1.5z"/>
                        <path d="M5 1a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H5zM4 2a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V2z"/>
                    </svg>
                </div>
                <h2 class="fw-bold tracking-tight">Hospital <span>Management</span></h2>
                <p class="text-secondary text-sm">Please sign in to access your dashboard</p>
            </div>

            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" autocomplete="off">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger bg-danger bg-opacity-10 border-danger border-opacity-20 text-danger text-sm rounded-8" role="alert"></div>

                <div class="mb-3">
                    <label asp-for="Username" class="form-label text-secondary text-xs fw-semibold uppercase tracking-wider">Username</label>
                    <input asp-for="Username" class="form-control" placeholder="e.g. admin01" />
                    <span asp-validation-for="Username" class="text-danger text-sm mt-1"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label text-secondary text-xs fw-semibold uppercase tracking-wider">Password</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger text-sm mt-1"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-3 mt-2 hover-translate">Sign In</button>
            </form>
            
            <div class="mt-4 pt-3 border-top border-secondary border-opacity-10 text-center">
                <div class="text-secondary text-xs">
                    Demo Accounts:<br />
                    Admin: <code class="text-primary">admin01</code> / <code class="text-secondary">123456</code><br />
                    Doctor: <code class="text-primary">doctor_tung</code> / <code class="text-secondary">123456</code><br />
                    Staff: <code class="text-primary">staff_hoa</code> / <code class="text-secondary">123456</code>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
